require "rake"

def run_command(command)
  puts "→ #{command}"
  system(command) || abort("Command failed: #{command}")
end

def with_args(base_command)
  extra_args = ENV["ARGS"].to_s.strip
  return base_command if extra_args.empty?

  "#{base_command} #{extra_args}"
end

# Load environment variables from .env.local file
def load_env_file(file_path)
  return unless File.exist?(file_path)

  File.readlines(file_path).each do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")

    key, value = line.split("=", 2)
    ENV[key] = value if key && value
  end
end

# Load .env.local for local development
load_env_file(".env.local")

def revenuecat_api_key
  ENV["REVENUECAT_API_KEY"].to_s
end

TASKS = {
  run_prod: {
    command: "fvm flutter run --flavor prod -t lib/main_prod.dart --dart-define=FLAVOR=prod",
    description: "Run app with prod flavor (set ARGS for extra flutter flags)",
  },
  run_local: {
    command: -> { "fvm flutter run --flavor stg -t lib/main_stg.dart --dart-define=FLAVOR=stg --dart-define=REVENUECAT_API_KEY=#{revenuecat_api_key}" },
    description: "Run app with stg flavor (set ARGS for extra flutter flags)",
  },
  format: {
    command: "fvm dart format lib test",
    description: "format dart files",
  },
  format_check: {
    command: "fvm dart format --output=none --set-exit-if-changed lib test",
    description: "Check dart files formatting",
  },
  test: {
    command: "fvm flutter test",
    description: "Run Flutter tests (set ARGS to pass extra options)",
  },
  lint: {
    command: "fvm flutter analyze",
    description: "Run Flutter analyzer (set ARGS to pass extra options)",
  },
  build_runner: {
    command: "fvm dart run build_runner build --delete-conflicting-outputs",
    description: "Run build_runner to generate code",
  },
  build_runner_watch: {
    command: "fvm dart run build_runner watch --delete-conflicting-outputs",
    description: "Run build_runner in watch mode",
  },
  pub_get: {
    command: "fvm flutter pub get",
    description: "Get dependencies",
  },
  clean: {
    command: "fvm flutter clean && fvm flutter pub get",
    description: "Clean and get dependencies",
  },
  generate_icons: {
    command: "fvm dart run flutter_launcher_icons",
    description: "Generate app launcher icons",
  },
  generate_splash: {
    command: "fvm dart run flutter_native_splash:create",
    description: "Generate native splash screens",
  },
}.freeze

TASKS.each do |name, config|
  desc config.fetch(:description)
  task name do
    command = config.fetch(:command)
    command = command.call if command.respond_to?(:call)
    run_command(with_args(command))
  end
end

desc "Default task runs the production flavor"
task default: :run_prod
